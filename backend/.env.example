# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/linkup

# Auth
JWT_SECRET=your_jwt_secret_key_here

# Server
PORT=5000
NODE_ENV=development

# Cloudinary (Media storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS (optional - only needed if you still use S3 somewhere)
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=linkup-media-bucket-2026

# Frontend URL (For CORS)
FRONTEND_URL=http://localhost:3000
# For production: FRONTEND_URL=https://linkup.yourdomain.com

# Socket.IO
SOCKET_ORIGIN=http://localhost:3000
# For production: SOCKET_ORIGIN=https://linkup.yourdomain.com
